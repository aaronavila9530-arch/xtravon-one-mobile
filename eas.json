{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_DEVICE_VARIANT": "celular"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "celular": {
      "distribution": "internal",
      "channel": "celular",
      "env": {
        "EXPO_PUBLIC_DEVICE_VARIANT": "celular"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "handheld": {
      "distribution": "internal",
      "channel": "handheld",
      "env": {
        "EXPO_PUBLIC_DEVICE_VARIANT": "handheld"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
